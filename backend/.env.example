# JARVIS Configuration
# Copy this file to .env and fill in your API keys

# AI Provider: "groq", "gemini", "ollama", "hybrid" (hybrid tries all in order)
AI_PROVIDER=hybrid

# Groq API Key (free at https://console.groq.com) - 100K tokens/day
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (free at https://aistudio.google.com/apikey) - 1.5M tokens/day
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Ollama (local, unlimited) - needs ollama installed
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Voice settings
VOICE_ENABLED=true

# Spotify (optional)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Server settings
HOST=0.0.0.0
PORT=8000
